{
	"name": "@dpopsuev/alef-eval",
	"version": "0.0.1",
	"description": "Evaluation harness for Alef agents — OTel span collection, RunMetrics, Pi-parsable reports",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"test": "vitest --run"
	},
	"dependencies": {
		"@dpopsuev/alef-corpus": "^0.0.1",
		"@dpopsuev/alef-organ-dialog": "^0.0.1",
		"@dpopsuev/alef-organ-fs": "^0.0.1",
		"@dpopsuev/alef-organ-llm": "^0.0.1",
		"@dpopsuev/alef-organ-shell": "^0.0.1",
		"@dpopsuev/alef-spine": "^0.0.1",
		"@dpopsuev/alef-testkit": "^0.0.1",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/context-async-hooks": "^2.7.1",
		"@opentelemetry/sdk-trace-base": "^1.30.1",
		"@opentelemetry/sdk-trace-node": "^2.7.1"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"shx": "^0.4.0",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	},
	"keywords": [
		"agent",
		"eval",
		"evaluation",
		"harness",
		"otel"
	],
	"author": "Daniel Popsuevich",
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	}
}
