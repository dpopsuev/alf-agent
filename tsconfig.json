{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@dpopsuev/alef-ai": ["./packages/ai/src/index.ts"],
			"@dpopsuev/alef-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@dpopsuev/alef-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@dpopsuev/alef-ai/dist/*": ["./packages/ai/src/*"],
			"@dpopsuev/alef-agent-core": ["./packages/agent/src/index.ts"],
			"@dpopsuev/alef-agent-core/*": ["./packages/agent/src/*"],
			"@dpopsuev/alef-agent-blueprint": ["./packages/blueprint/src/index.ts"],
			"@dpopsuev/alef-agent-blueprint/*": ["./packages/blueprint/src/*.ts"],
			"@dpopsuev/alef-agent-runtime": ["./packages/runtime/src/index.ts"],
			"@dpopsuev/alef-agent-runtime/*": ["./packages/runtime/src/*.ts"],
			"@dpopsuev/alef-spine": ["./packages/spine/src/index.ts"],
			"@dpopsuev/alef-spine/*": ["./packages/spine/src/*.ts"],
			"@dpopsuev/alef-corpus": ["./packages/corpus/src/index.ts"],
			"@dpopsuev/alef-corpus/*": ["./packages/corpus/src/*.ts"],
			"@dpopsuev/alef-testkit": ["./packages/testkit/src/index.ts"],
			"@dpopsuev/alef-testkit/*": ["./packages/testkit/src/*.ts"],
			"@dpopsuev/alef-discourse": ["./packages/discourse/src/index.ts"],
			"@dpopsuev/alef-discourse/*": ["./packages/discourse/src/*.ts"],
			"@dpopsuev/alef-organ-fs": ["./packages/organ-fs/src/index.ts"],
			"@dpopsuev/alef-organ-fs/*": ["./packages/organ-fs/src/*.ts"],
			"@dpopsuev/alef-organ-shell": ["./packages/organ-shell/src/index.ts"],
			"@dpopsuev/alef-organ-shell/*": ["./packages/organ-shell/src/*.ts"],
			"@dpopsuev/alef-organ-lector": ["./packages/organ-lector/src/index.ts"],
			"@dpopsuev/alef-organ-lector/*": ["./packages/organ-lector/src/*.ts"],
			"@dpopsuev/alef-organ-dialog": ["./packages/organ-dialog/src/index.ts"],
			"@dpopsuev/alef-organ-dialog/*": ["./packages/organ-dialog/src/*.ts"],
			"@dpopsuev/alef-organ-monolog": ["./packages/organ-monolog/src/index.ts"],
			"@dpopsuev/alef-organ-monolog/*": ["./packages/organ-monolog/src/*.ts"],
			"@dpopsuev/alef-organ-ai": ["./packages/organ-ai/src/index.ts"],
			"@dpopsuev/alef-organ-ai/*": ["./packages/organ-ai/src/*.ts", "./packages/organ-ai/src/completer/*.ts"],
			"@dpopsuev/alef-organ-supervisor": ["./packages/organ-supervisor/src/index.ts"],
			"@dpopsuev/alef-organ-supervisor/*": ["./packages/organ-supervisor/src/*.ts"],
			"@dpopsuev/alef-organ-discourse": ["./packages/organ-discourse/src/index.ts"],
			"@dpopsuev/alef-organ-discourse/*": ["./packages/organ-discourse/src/*.ts"],
			"@dpopsuev/alef-organ-completer": ["./packages/organ-completer/src/index.ts"],
			"@dpopsuev/alef-organ-completer/*": ["./packages/organ-completer/src/*.ts"],
			"@dpopsuev/alef-ui-domain": ["./packages/ui-domain/src/index.ts"],
			"@dpopsuev/alef-ui-domain/*": ["./packages/ui-domain/src/*.ts"],
			"@dpopsuev/alef-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@dpopsuev/alef-coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@dpopsuev/alef-coding-agent/*": ["./packages/coding-agent/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@dpopsuev/alef-tui": ["./packages/tui/src/index.ts"],
			"@dpopsuev/alef-tui/*": ["./packages/tui/src/*"],
			"@dpopsuev/alef-web-ui": ["./packages/web-ui/src/index.ts"],
			"@dpopsuev/alef-web-ui/*": ["./packages/web-ui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
